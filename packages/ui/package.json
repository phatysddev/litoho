{
  "name": "@litoho/ui",
  "version": "0.1.4",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phatysddev/litoho.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/phatysddev/litoho/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/phatysddev/litoho/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./badge": {
      "types": "./dist/badge.d.ts",
      "default": "./dist/badge.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "default": "./dist/button.js"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "default": "./dist/card.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "default": "./dist/dialog.js"
    },
    "./dropdown": {
      "types": "./dist/dropdown.d.ts",
      "default": "./dist/dropdown.js"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "default": "./dist/input.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "default": "./dist/select.js"
    },
    "./tabs": {
      "types": "./dist/tabs.d.ts",
      "default": "./dist/tabs.js"
    },
    "./toast": {
      "types": "./dist/toast.d.ts",
      "default": "./dist/toast.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/styles.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "lit": "^3.2.0"
  }
}
