{
  "name": "litoho-monorepo",
  "private": true,
  "version": "0.0.2",
  "description": "Litoho monorepo scaffold",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phatysddev/litoho.git"
  },
  "homepage": "https://github.com/phatysddev/litoho#readme",
  "bugs": {
    "url": "https://github.com/phatysddev/litoho/issues"
  },
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*",
    "playgrounds/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/router packages/server packages/app packages/cli packages/testing",
    "typecheck": "tsc -b packages/core packages/router packages/server packages/app packages/cli packages/testing",
    "test": "pnpm build && pnpm --filter @litoho/testing test",
    "clean": "rm -rf packages/*/dist playgrounds/*/dist",
    "release:pack": "node scripts/publish-packages.mjs --dry-run",
    "release:publish": "node scripts/publish-packages.mjs",
    "identity:preview": "node scripts/package-identity.mjs --preview",
    "identity:apply": "node scripts/package-identity.mjs --apply"
  },
  "devDependencies": {
    "litoho": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
