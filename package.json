{
  "name": "litoho-monorepo",
  "private": true,
  "version": "0.0.12",
  "description": "Litoho monorepo scaffold",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phatysddev/litoho.git"
  },
  "homepage": "https://github.com/phatysddev/litoho/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/phatysddev/litoho/issues"
  },
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*",
    "playgrounds/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/router packages/ui packages/server packages/app packages/cli packages/testing",
    "typecheck": "tsc -b packages/core packages/router packages/ui packages/server packages/app packages/cli packages/testing",
    "test": "pnpm build && pnpm --filter @litoho/testing test",
    "clean": "rm -rf packages/*/dist playgrounds/*/dist examples/*/dist",
    "release:bump": "node scripts/bump-version.mjs patch",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:report:check": "node scripts/check-release-report.mjs",
    "release:report:summary": "node scripts/render-release-summary.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "release:verify:published": "node scripts/release-verify.mjs --published --install --build --start",
    "release:smoke:new": "node scripts/smoke-new-app.mjs",
    "release:pack": "node scripts/publish-packages.mjs --dry-run",
    "release:publish": "node scripts/publish-packages.mjs",
    "release:publish:minor": "node scripts/publish-packages.mjs --bump minor",
    "release:publish:major": "node scripts/publish-packages.mjs --bump major",
    "release:publish:no-git": "LITOHO_AUTO_GIT=false node scripts/publish-packages.mjs",
    "identity:preview": "node scripts/package-identity.mjs --preview",
    "identity:apply": "node scripts/package-identity.mjs --apply"
  },
  "devDependencies": {
    "litoho": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
